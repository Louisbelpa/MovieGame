# Base de données
DB_PATH=./data/game.db

# Sécurité
COOKIE_SECRET=change_me_min_32_chars_random_string
ADMIN_PASSWORD=change_me_strong_password
ADMIN_USERNAME=admin

# CORS (production: domaine exact, pas *)
CORS_ORIGIN=https://guesstoday.fr,https://www.guesstoday.fr

# TMDB
TMDB_API_KEY=your_tmdb_api_key
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w1280

# Jeu
MAX_ATTEMPTS=5
WIKI_MAX_ATTEMPTS=3

# Features (Vite — lus au build)
VITE_ENABLE_SERIES=true
VITE_ENABLE_WIKI=true

# Sign in with Apple (web) — lus au build Vite ; en prod Docker / Railway ils doivent être
# disponibles pendant l’étape `npm run build` (variables « Build » sur Railway, voir Dockerfile).
# VITE_APPLE_CLIENT_ID=fr.guesstoday.web
# VITE_APPLE_REDIRECT_URI=https://guesstoday.fr/

# Google Sign-In (web) — Client ID OAuth 2.0 de la Google Cloud Console (type "Application Web").
# Obtenez-le sur https://console.cloud.google.com/apis/credentials
# VITE_GOOGLE_CLIENT_ID=

# Optionnel : domaine canonique pour Open Graph / partages (défaut : https://guesstoday.fr)
# VITE_PUBLIC_SITE_URL=https://guesstoday.fr

# Environnement
NODE_ENV=production
PORT=3000
VITE_ALLOW_PAST_SCHEDULING=false
