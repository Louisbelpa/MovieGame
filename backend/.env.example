# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite file path (relative to backend/)
DATABASE_PATH=./data/moviegame.db

# ─── Session / Cookie ─────────────────────────────────────────────────────────
# Secret used to sign session cookies (generate with: openssl rand -hex 32)
COOKIE_SECRET=change_me_with_a_long_random_secret_string

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Frontend origin allowed to call the API
CORS_ORIGIN=http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Max requests per window per IP for the /guess endpoint
GUESS_RATE_LIMIT_MAX=30
GUESS_RATE_LIMIT_WINDOW_MS=60000

# ─── Game Rules ───────────────────────────────────────────────────────────────
MAX_ATTEMPTS=6

# ─── Image source ─────────────────────────────────────────────────────────────
# "local"  → images served from /public/posters/
# "tmdb"   → images fetched from TMDB CDN (image_url stored as TMDB path)
IMAGE_SOURCE=tmdb
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500
