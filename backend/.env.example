# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────────────────────────
# Dev:        ./data/moviegame.db  (relative to backend/)
# Production: /data/moviegame.db  (mount a Railway/Render persistent volume at /data)
DATABASE_PATH=/data/moviegame.db

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate both with: openssl rand -hex 32
COOKIE_SECRET=CHANGE_ME_long_random_string
ADMIN_PASSWORD=CHANGE_ME_strong_password
# Optional: add a username requirement for the admin login (leave empty for password-only)
ADMIN_USERNAME=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your production domain — no trailing slash
# Railway example: https://moviegame-production.up.railway.app
CORS_ORIGIN=https://your-app.railway.app

# ─── TMDB ─────────────────────────────────────────────────────────────────────
# Get a free API key at https://www.themoviedb.org/settings/api
# Required for: random film button, backdrop picker
TMDB_API_KEY=CHANGE_ME_tmdb_api_key
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w1280

# ─── Upload URLs ─────────────────────────────────────────────────────────────
# Public base URL of the backend — used to build absolute image URLs for uploads
# Example: https://your-app.railway.app
BACKEND_URL=https://your-app.railway.app

# ─── Game rules ───────────────────────────────────────────────────────────────
MAX_ATTEMPTS=3
IMAGE_SOURCE=tmdb

# ─── Rate limiting ────────────────────────────────────────────────────────────
GUESS_RATE_LIMIT_MAX=30
GUESS_RATE_LIMIT_WINDOW_MS=60000
