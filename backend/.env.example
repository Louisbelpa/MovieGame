# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev: relative path inside backend/
# Railway:   /data/moviegame.db  (mount a Volume at /data in the Railway dashboard)
DATABASE_PATH=./data/moviegame.db

# ─── Session / Cookie ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
COOKIE_SECRET=change_me_with_a_long_random_secret_string

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Dev:        http://localhost:5173
# Production: https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────────────────────
GUESS_RATE_LIMIT_MAX=30
GUESS_RATE_LIMIT_WINDOW_MS=60000

# ─── Game Rules ───────────────────────────────────────────────────────────────
MAX_ATTEMPTS=6

# ─── Image source ─────────────────────────────────────────────────────────────
# "tmdb"  → poster paths stored as TMDB paths ("/abc.jpg"), CDN prepended at runtime
# "local" → images served from /public/posters/
IMAGE_SOURCE=tmdb
# w1280 gives widescreen scene quality; use w500 for smaller files
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w1280

# Optional: needed only to run `npm run fetch-backdrops`
# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=
