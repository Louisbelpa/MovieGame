{
  "name": "moviegame-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend API for the MovieGame daily cinema challenge",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && node -e \"require('fs').copyFileSync('src/db/schema.sql','dist/db/schema.sql')\"",
    "start": "node dist/db/migrate.js && node dist/server.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:backfill-wiki": "tsx scripts/backfill-wiki-persons.ts",
    "db:reset": "node --input-type=module -e \"import{rmSync}from'fs';rmSync(process.env.DATABASE_PATH??'data/moviegame.db',{force:true})\" && npm run db:migrate && npm run db:seed",
    "fetch-backdrops": "tsx scripts/fetch-backdrops.ts",
    "db:backfill-fame": "tsx scripts/backfill-fame.ts",
    "db:backup": "tsx scripts/backup.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/multer": "^2.1.0",
    "apple-signin-auth": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.6",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "file-type": "^22.0.1",
    "helmet": "^8.1.0",
    "lru-cache": "^11.3.5",
    "multer": "^2.1.1",
    "pino": "^9.0.0",
    "pino-http": "^11.0.0",
    "resend": "^6.12.3",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cookie-parser": "^1.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/supertest": "^7.2.0",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.2.2",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  }
}
